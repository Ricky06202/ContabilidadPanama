@page "/products"
@inject ApiService Api
@inject ISnackbar Snackbar

<PageTitle>Productos - ContabilidadPanama</PageTitle>

<MudGrid>
    <MudItem xs="12">
        <MudPaper Elevation="0" Class="page-header-gradient pa-4">
            <MudGrid AlignItems="AlignItems.Center">
                <MudItem xs="12" md="8">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="mr-3" Style="font-size: 2.5rem; color: white;" />
                        <div>
                            <MudText Typo="Typo.h5" Style="font-weight: 700; color: white;">Productos</MudText>
                            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">Gestiona tu inventario</MudText>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="12" md="4" Class="d-flex justify-content-md-end">
                    <MudButton Variant="Variant.Filled" Color="Color.Default" StartIcon="@Icons.Material.Filled.Add" Class="header-action-btn">Nuevo Producto</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Elevation="2" Class="mt-4" Style="border-radius: 16px;">
    <MudToolBar Class="pa-3">
        <MudTextField @bind-Value="searchString" 
                     Placeholder="Buscar productos..." 
                     Adornment="Adornment.Start"
                     AdornmentIcon="@Icons.Material.Filled.Search"
                     Immediate="true"
                     Class="mr-3"
                     Style="max-width: 300px;" />
        
        <MudSpacer />
        
        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary" 
                  StartIcon="@Icons.Material.Filled.Add">
            Nuevo Producto
        </MudButton>
    </MudToolBar>

    <MudTable Items="@filteredProducts" 
              Dense="true" 
              Hover="true" 
              Striped="true"
              Loading="@isLoading"
              Elevation="0">
        <HeaderContent>
            <MudTh>Código</MudTh>
            <MudTh>Nombre</MudTh>
            <MudTh>Categoría</MudTh>
            <MudTh>Precio</MudTh>
            <MudTh>Stock</MudTh>
            <MudTh Style="text-align: center;">Acciones</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                    @context.Code
                </MudChip>
            </MudTd>
            <MudTd Style="font-weight: 500;">@context.Name</MudTd>
            <MudTd>@context.Category</MudTd>
            <MudTd Style="font-weight: 600;">$@context.Price.ToString("N2")</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@(context.Stock <= 10 ? Color.Warning : Color.Success)" Variant="Variant.Filled">
                    @context.Stock
                </MudChip>
            </MudTd>
            <MudTd Style="text-align: center;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No se encontraron productos</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<ProductDto> products = new();
    private string searchString = "";
    private bool isLoading = true;
    
    private IEnumerable<ProductDto> filteredProducts => string.IsNullOrEmpty(searchString) 
        ? products 
        : products.Where(p => p.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false);

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        isLoading = true;
        try
        {
            products = await Api.GetAsync<List<ProductDto>>("/products") ?? new();
        }
        catch { products = GetSampleProducts(); }
        finally { isLoading = false; }
    }

    private List<ProductDto> GetSampleProducts() => new()
    {
        new() { Id = 1, Code = "PROD-001", Name = "Laptop Dell XPS 15", Category = "Electrónica", Price = 1200.00m, Stock = 15 },
        new() { Id = 2, Code = "PROD-002", Name = "Monitor LG 27\"", Category = "Electrónica", Price = 350.00m, Stock = 8 },
        new() { Id = 3, Code = "PROD-003", Name = "Teclado Mecánico", Category = "Accesorios", Price = 85.00m, Stock = 25 }
    };

    public class ProductDto
    {
        public int Id { get; set; }
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public string Category { get; set; } = "";
        public decimal Price { get; set; }
        public int Stock { get; set; }
    }
}

<style>
    .page-header-gradient { background: linear-gradient(135deg, #10B981 0%, #059669 100%); border-radius: 16px !important; }
    .header-action-btn { background-color: white !important; color: #10B981 !important; font-weight: 600; border-radius: 10px; }
</style>
