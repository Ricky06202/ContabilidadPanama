@* Accounts Receivable Report *@
@if (ReportType == "accounts-receivable")
{
    <MudPaper Elevation="2" Style="border-radius: 16px;" Class="pa-4">
        <MudText Typo="Typo.h6" Style="font-weight: 600;" Class="mb-4">Cuentas por Cobrar</MudText>
        
        <MudTable Items="@receivables" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>Cliente</MudTh>
                <MudTh>Factura</MudTh>
                <MudTh>Fecha</MudTh>
                <MudTh>Vence</MudTh>
                <MudTh style="text-align: right;">Monto</MudTh>
                <MudTh>Días Venc.</MudTh>
                <MudTh>Estado</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="font-weight: 500;">@context.Client</MudTd>
                <MudTd>@context.Invoice</MudTd>
                <MudTd>@context.Date</MudTd>
                <MudTd>@context.DueDate</MudTd>
                <MudTd Style="text-align: right;">$@context.Amount.ToString("N2")</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@(context.DaysOverdue > 30 ? Color.Error : context.DaysOverdue > 0 ? Color.Warning : Color.Success)">
                        @context.DaysOverdue
                    </MudChip>
                </MudTd>
                <MudTd>@context.Status</MudTd>
            </RowTemplate>
