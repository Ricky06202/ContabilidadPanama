@page "/reports"
@page "/reports/{ReportType}"
@inject ApiService Api
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Reportes - ContabilidadPanama</PageTitle>

<MudGrid>
    <MudItem xs="12">
        <MudPaper Elevation="0" Class="page-header-gradient pa-4">
            <MudGrid AlignItems="AlignItems.Center">
                <MudItem xs="12" md="8">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-3" Style="font-size: 2.5rem; color: white;" />
                        <div>
                            <MudText Typo="Typo.h5" Style="font-weight: 700; color: white;">Reportes</MudText>
                            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">Análisis financiero y estados de cuenta</MudText>
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>

@if (string.IsNullOrEmpty(ReportType))
{
    <MudGrid>
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="2" Style="border-radius: 16px; cursor: pointer;" Class="pa-4 report-card" @onclick='() => NavigateTo("income-statement")'>
                <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Large" Color="Color.Primary" Class="mb-3" />
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Estado de Resultados</MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.7;">Resumen de ingresos y gastos</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="2" Style="border-radius: 16px; cursor: pointer;" Class="pa-4 report-card" @onclick='() => NavigateTo("balance-sheet")'>
                <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Balance General</MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.7;">Situación financiera actual</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="2" Style="border-radius: 16px; cursor: pointer;" Class="pa-4 report-card" @onclick='() => NavigateTo("cash-flow")'>
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Large" Color="Color.Success" Class="mb-3" />
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Flujo de Caja</MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.7;">Movimientos de efectivo</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="2" Style="border-radius: 16px; cursor: pointer;" Class="pa-4 report-card" @onclick='() => NavigateTo("general-ledger")'>
                <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Large" Color="Color.Warning" Class="mb-3" />
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Libro Mayor</MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.7;">Detalle de cuentas</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="2" Style="border-radius: 16px; cursor: pointer;" Class="pa-4 report-card" @onclick='() => NavigateTo("accounts-receivable")'>
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Error" Class="mb-3" />
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Cuentas por Cobrar</MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.7;">Clientes pendientes</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="2" Style="border-radius: 16px; cursor: pointer;" Class="pa-4 report-card" @onclick='() => NavigateTo("accounts-payable")'>
                <MudIcon Icon="@Icons.Material.Filled.CreditCard" Size="Size.Large" Color="Color.Info" Class="mb-3" />
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Cuentas por Pagar</MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.7;">Proveedores pendientes</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="2" Style="border-radius: 16px; cursor: pointer;" Class="pa-4 report-card" @onclick='() => NavigateTo("inventory")'>
                <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Large" Color="Color.Primary" Class="mb-3" />
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Inventario</MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.7;">Resumen de productos</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="2" Style="border-radius: 16px; cursor: pointer;" Class="pa-4 report-card" @onclick='() => NavigateTo("payroll-report")'>
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Nómina</MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.7;">Resumen de empleados</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
else
{
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="BackToReports" Class="mb-4">
        Volver a Reportes
    </MudButton>
    
    <MudPaper Elevation="2" Style="border-radius: 16px;" Class="pa-4 mb-4">
        <MudGrid AlignItems="AlignItems.Center">
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.h5" Style="font-weight: 600;">@GetReportTitle()</MudText>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudDatePicker Label="Fecha Inicio" @bind-Date="startDate" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudDatePicker Label="Fecha Fin" @bind-Date="endDate" />
            </MudItem>
        </MudGrid>
        <MudStack Row="true" Class="mt-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadReportData">
                Generar Reporte
            </MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.PictureAsPdf">
                Exportar PDF
            </MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FileCopy">
                Exportar Excel
            </MudButton>
        </MudStack>
    </MudPaper>
    
    @switch (ReportType)
    {
        case "income-statement":
            <IncomeStatementReport Data="@reportData" />
            break;
        case "balance-sheet":
            <BalanceSheetReport Data="@reportData" />
            break;
        case "cash-flow":
            <CashFlowReport Data="@reportData" />
            break;
        case "general-ledger":
            <GeneralLedgerReport Data="@reportData" />
            break;
        case "accounts-receivable":
            <AccountsReceivableReport Data="@reportData" />
            break;
        case "accounts-payable":
            <AccountsPayableReport Data="@reportData" />
            break;
        case "inventory":
            <InventoryReport Data="@reportData" />
            break;
        case "payroll-report":
            <PayrollReport Data="@reportData" />
            break;
    }
}

@code {
    [Parameter]
    public string? ReportType { get; set; }
    
    private DateTime? startDate = DateTime.Now.AddMonths(-1);
    private DateTime? endDate = DateTime.Now;
    private object? reportData;
    
    private void NavigateTo(string report)
    {
        Navigation.NavigateTo($"/reports/{report}");
    }
    
    private void BackToReports()
    {
        Navigation.NavigateTo("/reports");
    }
    
    private string GetReportTitle() => ReportType switch
    {
        "income-statement" => "Estado de Resultados",
        "balance-sheet" => "Balance General",
        "cash-flow" => "Flujo de Caja",
        "general-ledger" => "Libro Mayor",
        "accounts-receivable" => "Cuentas por Cobrar",
        "accounts-payable" => "Cuentas por Pagar",
        "inventory" => "Inventario",
        "payroll-report" => "Nómina",
        _ => "Reporte"
    };
    
    private async Task LoadReportData()
    {
        Snackbar.Add($"Generando reporte de {GetReportTitle()}...", Severity.Info);
        await Task.Delay(500);
    }
}

