@page "/clients"
@page "/clients/{Id:int}"
@inject ApiService Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Clientes - ContabilidadPanama</PageTitle>

<!-- Modern Page Header -->
<MudGrid>
    <MudItem xs="12">
        <MudPaper Elevation="0" Class="page-header-gradient pa-4">
            <MudGrid AlignItems="AlignItems.Center">
                <MudItem xs="12" md="8">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-3" Style="font-size: 2.5rem; color: white;" />
                        <div>
                            <MudText Typo="Typo.h5" Style="font-weight: 700; color: white;">
                                Clientes
                            </MudText>
                            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">
                                Gestiona tu directorio de clientes
                            </MudText>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="12" md="4" Class="d-flex justify-content-md-end">
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Default" 
                              StartIcon="@Icons.Material.Filled.Add"
                              OnClick="OpenCreateDialog"
                              Class="header-action-btn">
                        Nuevo Cliente
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Elevation="2" Class="mt-4" Style="border-radius: 16px;">
    <MudToolBar Class="pa-3">
        <MudTextField @bind-Value="searchString" 
                     Placeholder="Buscar clientes..." 
                     Adornment="Adornment.Start"
                     AdornmentIcon="@Icons.Material.Filled.Search"
                     Immediate="true"
                     Class="mr-3"
                     Style="max-width: 300px;" />
        
        <MudSpacer />
        
        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary" 
                  StartIcon="@Icons.Material.Filled.Add"
                  OnClick="OpenCreateDialog">
            Nuevo Cliente
        </MudButton>
    </MudToolBar>

    <MudTable Items="@filteredClients" 
              Dense="true" 
              Hover="true" 
              Striped="true"
              Loading="@isLoading"
              Elevation="0">
        <HeaderContent>
            <MudTh>RUC</MudTh>
            <MudTh>Nombre</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Teléfono</MudTh>
            <MudTh>Dirección</MudTh>
            <MudTh Style="text-align: center;">Acciones</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                    @context.Ruc
                </MudChip>
            </MudTd>
            <MudTd Style="font-weight: 500;">@context.Name</MudTd>
            <MudTd>@context.Email</MudTd>
            <MudTd>@context.Phone</MudTd>
            <MudTd Class="d-none d-md-table-cell">@context.Address</MudTd>
            <MudTd Style="text-align: center;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                              Color="Color.Primary" 
                              Size="Size.Small"
                              OnClick="@(() => OpenEditDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                              Color="Color.Error" 
                              Size="Size.Small"
                              OnClick="@(() => DeleteClient(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No se encontraron clientes</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Cargando clientes...</MudText>
        </LoadingContent>
    </MudTable>
</MudPaper>

<MudDialog @bind-IsOpen="dialogOpen">
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="formValid">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="editingClient.Ruc" 
                                 Label="RUC" 
                                 Required="true"
                                 RequiredError="El RUC es requerido" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="editingClient.Name" 
                                 Label="Nombre / Razón Social" 
                                 Required="true"
                                 RequiredError="El nombre es requerido" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="editingClient.Email" 
                                 Label="Email" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="editingClient.Phone" 
                                 Label="Teléfono" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="editingClient.Address" 
                                 Label="Dirección" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog">Cancelar</MudButton>
        <MudButton Color="Color.Primary" 
                  Variant="Variant.Filled" 
                  OnClick="SaveClient"
                  Disabled="!formValid">
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public int? Id { get; set; }
    
    private List<ClientDto> clients = new();
    private string searchString = "";
    private bool isLoading = true;
    private bool dialogOpen = false;
    private bool isNewClient = true;
    private ClientDto editingClient = new();
    private MudForm? form;
    private bool formValid;
    
    private IEnumerable<ClientDto> filteredClients => string.IsNullOrEmpty(searchString) 
        ? clients 
        : clients.Where(c => 
            (c.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (c.Ruc?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (c.Email?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await LoadClients();
    }

    private async Task LoadClients()
    {
        isLoading = true;
        try
        {
            clients = await Api.GetAsync<List<ClientDto>>("/clients") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading clients: {ex.Message}");
            Snackbar.Add("Error al cargar clientes", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateDialog()
    {
        isNewClient = true;
        editingClient = new ClientDto();
        dialogOpen = true;
    }

    private void OpenEditDialog(ClientDto client)
    {
        isNewClient = false;
        editingClient = new ClientDto
        {
            Id = client.Id,
            Ruc = client.Ruc,
            Name = client.Name,
            Email = client.Email,
            Phone = client.Phone,
            Address = client.Address
        };
        dialogOpen = true;
    }

    private void CloseDialog()
    {
        dialogOpen = false;
    }

    private async Task SaveClient()
    {
        if (isNewClient)
        {
            var created = await Api.PostAsync<ClientDto>("/clients", editingClient);
            if (created != null)
            {
                clients.Add(created);
                Snackbar.Add("Cliente creado exitosamente", Severity.Success);
            }
        }
        else
        {
            var result = await Api.PutAsync<ClientDto>($"/clients/{editingClient.Id}", editingClient);
            if (result != null)
            {
                var index = clients.FindIndex(c => c.Id == editingClient.Id);
                if (index >= 0)
                {
                    clients[index] = result;
                }
                Snackbar.Add("Cliente actualizado exitosamente", Severity.Success);
            }
        }
        CloseDialog();
    }

    private async Task DeleteClient(ClientDto client)
    {
        var parameters = new DialogParameters<ConfirmDialog>();
        parameters.Add(x => x.ContentText, $"¿Está seguro de eliminar el cliente {client.Name}?");
        parameters.Add(x => x.ButtonText, "Eliminar");
        parameters.Add(x => x.Color, Color.Error);

        var options = new DialogOptions { CloseOnEscapeKey = true };
        
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirmar eliminación", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var success = await Api.DeleteAsync($"/clients/{client.Id}");
            if (success)
            {
                clients.Remove(client);
                Snackbar.Add("Cliente eliminado", Severity.Success);
            }
        }
    }
}

<style>
    .page-header-gradient {
        background: linear-gradient(135deg, #2563EB 0%, #7C3AED 100%);
        border-radius: 16px !important;
    }
    
    .header-action-btn {
        background-color: white !important;
        color: #2563EB !important;
        font-weight: 600;
        border-radius: 10px;
    }
    
    .header-action-btn:hover {
        background-color: rgba(255,255,255,0.9) !important;
        transform: translateY(-2px);
    }
</style>
