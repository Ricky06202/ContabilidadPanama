@page "/providers"
@inject ApiService Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Proveedores - ContabilidadPanama</PageTitle>

<MudText Typo="Typo.h4" Style="font-weight: 700;" Class="mb-4">Proveedores</MudText>

<MudPaper Elevation="2" Style="border-radius: 16px;">
    <MudToolBar Class="pa-3">
        <MudTextField @bind-Value="searchString" 
                     Placeholder="Buscar proveedores..." 
                     Adornment="Adornment.Start"
                     AdornmentIcon="@Icons.Material.Filled.Search"
                     Immediate="true"
                     Class="mr-3"
                     Style="max-width: 300px;" />
        
        <MudSpacer />
        
        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary" 
                  StartIcon="@Icons.Material.Filled.Add"
                  OnClick="OpenCreateDialog">
            Nuevo Proveedor
        </MudButton>
    </MudToolBar>

    <MudTable Items="@filteredProviders" 
              Dense="true" 
              Hover="true" 
              Striped="true"
              Loading="@isLoading"
              Elevation="0">
        <HeaderContent>
            <MudTh>RUC</MudTh>
            <MudTh>Nombre</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Teléfono</MudTh>
            <MudTh>Dirección</MudTh>
            <MudTh Style="text-align: center;">Acciones</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">
                    @context.Ruc
                </MudChip>
            </MudTd>
            <MudTd Style="font-weight: 500;">@context.Name</MudTd>
            <MudTd>@context.Email</MudTd>
            <MudTd>@context.Phone</MudTd>
            <MudTd Class="d-none d-md-table-cell">@context.Address</MudTd>
            <MudTd Style="text-align: center;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No se encontraron proveedores</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Cargando proveedores...</MudText>
        </LoadingContent>
    </MudTable>
</MudPaper>

@code {
    private List<Proveedor> providers = new();
    private string searchString = "";
    private bool isLoading = true;
    
    private IEnumerable<Proveedor> filteredProviders => string.IsNullOrEmpty(searchString) 
        ? providers 
        : providers.Where(p => 
            (p.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (p.Ruc?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (p.Email?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await LoadProviders();
    }

    private async Task LoadProviders()
    {
        isLoading = true;
        try
        {
            providers = await Api.GetAsync<List<Proveedor>>("/providers") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading providers: {ex.Message}");
            Snackbar.Add("Error al cargar proveedores", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateDialog()
    {
        Snackbar.Add("Crear proveedor - en desarrollo", Severity.Info);
    }

    public class Proveedor
    {
        public int Id { get; set; }
        public string Ruc { get; set; } = "";
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Address { get; set; } = "";
    }
}
