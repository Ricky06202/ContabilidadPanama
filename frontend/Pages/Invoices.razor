@page "/invoices"
@inject ApiService Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Facturas - ContabilidadPanama</PageTitle>

<MudText Typo="Typo.h4" Style="font-weight: 700;" Class="mb-4">Facturas</MudText>

<MudPaper Elevation="2" Style="border-radius: 16px;">
    <MudToolBar Class="pa-3">
        <MudTextField @bind-Value="searchString" 
                     Placeholder="Buscar facturas..." 
                     Adornment="Adornment.Start"
                     AdornmentIcon="@Icons.Material.Filled.Search"
                     Immediate="true"
                     Class="mr-3"
                     Style="max-width: 300px;" />
        
        <MudSpacer />
        
        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary" 
                  StartIcon="@Icons.Material.Filled.Add"
                  OnClick="OpenCreateDialog">
            Nueva Factura
        </MudButton>
    </MudToolBar>

    <MudTable Items="@filteredInvoices" 
              Dense="true" 
              Hover="true" 
              Striped="true"
              Loading="@isLoading"
              Elevation="0">
        <HeaderContent>
            <MudTh>Número</MudTh>
            <MudTh>Fecha</MudTh>
            <MudTh>Cliente</MudTh>
            <MudTh>Total</MudTh>
            <MudTh>Estado</MudTh>
            <MudTh Style="text-align: center;">Acciones</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                    @context.InvoiceNumber
                </MudChip>
            </MudTd>
            <MudTd>@context.IssueDate?.ToString("dd/MM/yyyy")</MudTd>
            <MudTd Style="font-weight: 500;">@context.ClientName</MudTd>
            <MudTd Style="font-weight: 600;">$@context.Total.ToString("N2")</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd Style="text-align: center;">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Primary" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No se encontraron facturas</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Cargando facturas...</MudText>
        </LoadingContent>
    </MudTable>
</MudPaper>

@code {
    private List<InvoiceDto> invoices = new();
    private string searchString = "";
    private bool isLoading = true;
    
    private IEnumerable<InvoiceDto> filteredInvoices => string.IsNullOrEmpty(searchString) 
        ? invoices 
        : invoices.Where(i => 
            (i.InvoiceNumber?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (i.ClientName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await LoadInvoices();
    }

    private async Task LoadInvoices()
    {
        isLoading = true;
        try
        {
            invoices = await Api.GetAsync<List<InvoiceDto>>("/invoices") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading invoices: {ex.Message}");
            Snackbar.Add("Error al cargar facturas", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateDialog()
    {
        Snackbar.Add("Crear factura - en desarrollo", Severity.Info);
    }

    private Color GetStatusColor(string status) => status?.ToLower() switch
    {
        "pagada" => Color.Success,
        "pendiente" => Color.Warning,
        "vencida" => Color.Error,
        "cancelada" => Color.Default,
        _ => Color.Default
    };

    public class InvoiceDto
    {
        public int Id { get; set; }
        public string InvoiceNumber { get; set; } = "";
        public DateTime? IssueDate { get; set; }
        public string ClientName { get; set; } = "";
        public decimal Total { get; set; }
        public string Status { get; set; } = "";
    }
}
