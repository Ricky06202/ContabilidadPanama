@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject ThemeService Theme
@using System.Globalization
@using System.ComponentModel

<MudThemeProvider Theme="@Theme.CurrentTheme" @bind-IsDarkMode="@Theme.IsDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Class="app-bar-modern">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@DrawerToggle" Class="menu-btn" />
        
        <MudText Typo="Typo.h6" Class="ml-3 brand-text">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Medium" Class="mr-2 brand-icon" />
            <span class="brand-name">ContabilidadPanama</span>
        </MudText>
        
        <MudSpacer />
        
        <MudText Typo="Typo.body2" Class="mr-4 d-none d-md-flex date-display">
            @currentDate.ToString("dddd, d MMMM yyyy", spanishCulture)
        </MudText>
        
        <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Inherit" Class="icon-btn" Title="Buscar (Ctrl+K)" />
        
        <MudIconButton Icon="@(Theme.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                       Color="Color.Inherit" 
                       OnClick="@ToggleTheme" 
                       Class="icon-btn"
                       Title="@(Theme.IsDarkMode ? "Modo Claro" : "Modo Oscuro")" />
        
        <MudMenu Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" Class="icon-btn">
            <MudMenuItem>
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                    <MudText>3 facturas pendientes</MudText>
                </MudStack>
            </MudMenuItem>
            <MudMenuItem>
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" />
                    <MudText>Nuevo reporte disponible</MudText>
                </MudStack>
            </MudMenuItem>
        </MudMenu>
        
        <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit" Class="icon-btn">
            <MudMenuItem Href="/profile">
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
                Mi Perfil
            </MudMenuItem>
            <MudMenuItem Href="/settings">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
                Configuración
            </MudMenuItem>
            <MudDivider />
            <MudMenuItem OnClick="Logout">
                <MudIcon Icon="@Icons.Material.Filled.Logout" Class="mr-2" />
                Cerrar Sesión
            </MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen" Elevation="2" Variant="@DrawerVariant.Mini" MiniWidth="72px" ClipMode="DrawerClipMode.Always" Class="sidebar-modern">
        <MudDrawerHeader Class="pa-3 sidebar-header">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Large" Color="Color.Primary" Class="sidebar-logo" />
        </MudDrawerHeader>

        <MudNavMenu Rounded="true" Margin="Margin.Dense" Class="nav-menu-custom">
            <MudTooltip Text="Dashboard" Placement="Placement.Right">
                <MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All" Class="nav-item">
                    <MudText Class="nav-text">Dashboard</MudText>
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Facturación" Placement="Placement.Right">
                <MudNavLink Href="/invoices" Icon="@Icons.Material.Filled.Description" Class="nav-item">
                    <MudText Class="nav-text">Facturas</MudText>
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Clientes" Placement="Placement.Right">
                <MudNavLink Href="/clients" Icon="@Icons.Material.Filled.People" Class="nav-item">
                    <MudText Class="nav-text">Clientes</MudText>
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Proveedores" Placement="Placement.Right">
                <MudNavLink Href="/providers" Icon="@Icons.Material.Filled.LocalShipping" Class="nav-item">
                    <MudText Class="nav-text">Proveedores</MudText>
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Productos" Placement="Placement.Right">
                <MudNavLink Href="/products" Icon="@Icons.Material.Filled.Inventory2" Class="nav-item">
                    <MudText Class="nav-text">Productos</MudText>
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Gastos" Placement="Placement.Right">
                <MudNavLink Href="/expenses" Icon="@Icons.Material.Filled.Payments" Class="nav-item">
                    <MudText Class="nav-text">Gastos</MudText>
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Bancos" Placement="Placement.Right">
                <MudNavLink Href="/banking" Icon="@Icons.Material.Filled.AccountBalance" Class="nav-item">
                    <MudText Class="nav-text">Bancos</MudText>
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Nómina" Placement="Placement.Right">
                <MudNavLink Href="/payroll" Icon="@Icons.Material.Filled.Badge" Class="nav-item">
                    <MudText Class="nav-text">Nómina</MudText>
                </MudNavLink>
            </MudTooltip>
            
            <MudDivider Class="my-3 nav-divider" />
            
            <MudTooltip Text="Reportes" Placement="Placement.Right">
                <MudNavLink Href="/reports" Icon="@Icons.Material.Filled.Analytics" Class="nav-item">
                    <MudText Class="nav-text">Reportes</MudText>
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Configuración" Placement="Placement.Right">
                <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings" Class="nav-item">
                    <MudText Class="nav-text">Ajustes</MudText>
                </MudNavLink>
            </MudTooltip>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4 main-content">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    <MudAlert Severity="Severity.Error" Dense="true">
        Se produjo un error. Por favor, recarga la página.
    </MudAlert>
    <button class="reload" onclick="location.reload()">Recargar</button>
    <button class="dismiss">Dismiss</button>
</div>

@code {
    private bool _drawerOpen = true;
    private readonly DateTime currentDate = DateTime.Now;
    private readonly CultureInfo spanishCulture = new CultureInfo("es-PA");

    protected override async Task OnInitializedAsync()
    {
        Theme.PropertyChanged += OnThemeChanged;
        await Theme.LoadPreferenceAsync();
    }

    private void OnThemeChanged(object? sender, PropertyChangedEventArgs e)
    {
        if (e.PropertyName == nameof(ThemeService.IsDarkMode) || e.PropertyName == nameof(ThemeService.CurrentTheme))
        {
            StateHasChanged();
        }
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private async Task ToggleTheme()
    {
        Theme.ToggleTheme();
        await Theme.SavePreferenceAsync();
    }

    private void Logout()
    {
        Navigation.NavigateTo("/login");
    }
}

<style>
    .app-bar-modern {
        background: linear-gradient(135deg, #2563EB 0%, #7C3AED 100%) !important;
        backdrop-filter: blur(10px);
    }
    
    .menu-btn {
        transition: transform 0.2s ease;
    }
    
    .menu-btn:hover {
        transform: scale(1.1);
    }
    
    .brand-text {
        font-weight: 700;
        letter-spacing: -0.5px;
        display: flex;
        align-items: center;
    }
    
    .brand-icon {
        color: white;
    }
    
    .brand-name {
        background: linear-gradient(135deg, #fff 0%, #e0e7ff 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    
    .date-display {
        color: rgba(255, 255, 255, 0.9);
        font-weight: 500;
    }
    
    .icon-btn {
        transition: all 0.2s ease;
        border-radius: 10px;
    }
    
    .icon-btn:hover {
        background: rgba(255, 255, 255, 0.15);
        transform: scale(1.05);
    }
    
    .sidebar-modern {
        background: var(--mud-palette-drawer-background) !important;
        border-right: 1px solid var(--mud-palette-divider);
    }
    
    .sidebar-header {
        display: flex;
        justify-content: center;
        padding: 16px !important;
    }
    
    .sidebar-logo {
        opacity: 0.9;
    }
    
    .nav-menu-custom {
        padding: 8px 12px;
    }
    
    .nav-item {
        border-radius: 12px !important;
        margin-bottom: 4px !important;
        padding: 12px 16px !important;
        transition: all 0.2s ease;
    }
    
    .nav-item:hover {
        background: rgba(37, 99, 235, 0.08) !important;
        transform: translateX(4px);
    }
    
    .nav-item.active {
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.15) 0%, rgba(124, 58, 237, 0.15) 100%) !important;
        border-left: 3px solid #2563EB;
    }
    
    .nav-text {
        font-weight: 500;
        font-size: 0.9rem;
    }
    
    .nav-divider {
        margin: 12px 0 !important;
        opacity: 0.5;
    }
    
    .main-content {
        min-height: calc(100vh - 64px);
    }
    
    :root {
        --font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    
    body {
        font-family: var(--font-family);
    }
    
    #blazor-error-ui {
        display: none;
    }
    
    /* Modern card styling */
    .mud-card {
        border-radius: 16px !important;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06) !important;
        transition: all 0.3s ease !important;
    }
    
    .mud-card:hover {
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05) !important;
        transform: translateY(-2px);
    }
    
    /* Modern button styling */
    .mud-button {
        border-radius: 10px !important;
        font-weight: 600 !important;
        text-transform: none !important;
        transition: all 0.2s ease !important;
    }
    
    .mud-button:hover {
        transform: translateY(-1px);
    }
    
    /* Modern table styling */
    .mud-table-root {
        border-radius: 12px;
        overflow: hidden;
    }
    
    .mud-table-head {
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    }
    
    .mud-table-row:hover {
        background: rgba(37, 99, 235, 0.04) !important;
    }
    
    /* Smooth transitions */
    * {
        transition-property: background-color, border-color, color, fill, stroke;
        transition-timing-function: ease;
        transition-duration: 150ms;
    }
    
    /* Mobile Responsiveness */
    .header-icon {
        font-size: 2rem;
    }
    
    @@media (max-width: 600px) {
        .brand-name {
            display: none;
        }
        
        .app-bar-modern {
            padding: 0 8px !important;
        }
        
        .menu-btn, .icon-btn {
            padding: 6px !important;
        }
        
        .nav-item {
            padding: 10px 12px !important;
        }
        
        .nav-text {
            display: none;
        }
        
        .mud-main-content {
            padding: 8px !important;
        }
        
        .mud-paper {
            border-radius: 12px !important;
        }
        
        .page-header-gradient {
            padding: 16px !important;
        }
        
        .page-header-gradient .header-icon {
            font-size: 1.5rem !important;
            margin-right: 8px !important;
        }
        
        .page-header-gradient .mud-typography-h5 {
            font-size: 1.25rem !important;
        }
        
        .page-header-gradient .mud-typography-body2 {
            font-size: 0.75rem !important;
        }
        
        .header-action-btn {
            font-size: 0.75rem !important;
            padding: 6px 12px !important;
        }
    }
</style>
