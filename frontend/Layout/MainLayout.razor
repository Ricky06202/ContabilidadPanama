@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject ThemeService Theme
@using System.Globalization
@using System.ComponentModel

<MudThemeProvider Theme="@Theme.CurrentTheme" @bind-IsDarkMode="@Theme.IsDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Class="app-bar-modern">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="@DrawerToggle" Class="menu-btn" />
        
        <MudText Typo="Typo.h6" Class="ml-2 brand-text">
            <span class="brand-name">ContabilidadPanama</span>
        </MudText>
        
        <MudSpacer />
        
        <MudHidden Breakpoint="Breakpoint.SmAndUp" Invert="true">
            <MudText Typo="Typo.body2" Class="mr-4 date-display">
                @currentDate.ToString("d MMM", spanishCulture)
            </MudText>
        </MudHidden>
        
        <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Inherit" Class="icon-btn" Title="Buscar" />
        
        <MudIconButton Icon="@(Theme.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                       Color="Color.Inherit" 
                       OnClick="@ToggleTheme" 
                       Class="icon-btn"
                       Title="@(Theme.IsDarkMode ? "Modo Claro" : "Modo Oscuro")" />
        
        <MudMenu Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" Class="icon-btn">
            <MudMenuItem>
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                    <MudText>3 facturas pendientes</MudText>
                </MudStack>
            </MudMenuItem>
            <MudMenuItem>
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" />
                    <MudText>Nuevo reporte disponible</MudText>
                </MudStack>
            </MudMenuItem>
        </MudMenu>
        
        <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit" Class="icon-btn">
            <MudMenuItem Href="/profile">
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
                Mi Perfil
            </MudMenuItem>
            <MudMenuItem Href="/settings">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
                Configuración
            </MudMenuItem>
            <MudDivider />
            <MudMenuItem OnClick="Logout">
                <MudIcon Icon="@Icons.Material.Filled.Logout" Class="mr-2" />
                Cerrar Sesión
            </MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen" 
               Elevation="4" 
               Variant="@DrawerVariant.Temporary" 
               Class="sidebar-modern">
        <MudDrawerHeader Class="pa-2 sidebar-header">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Medium" Color="Color.Primary" />
        </MudDrawerHeader>

        <MudNavMenu Rounded="true" Margin="Margin.Dense" Class="nav-menu-custom">
            <MudTooltip Text="Dashboard" Placement="Placement.Right">
                <MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All" Class="nav-item">
                    Dashboard
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Facturación" Placement="Placement.Right">
                <MudNavLink Href="/invoices" Icon="@Icons.Material.Filled.Description" Class="nav-item">
                    Facturas
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Clientes" Placement="Placement.Right">
                <MudNavLink Href="/clients" Icon="@Icons.Material.Filled.People" Class="nav-item">
                    Clientes
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Proveedores" Placement="Placement.Right">
                <MudNavLink Href="/providers" Icon="@Icons.Material.Filled.LocalShipping" Class="nav-item">
                    Proveedores
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Productos" Placement="Placement.Right">
                <MudNavLink Href="/products" Icon="@Icons.Material.Filled.Inventory2" Class="nav-item">
                    Productos
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Gastos" Placement="Placement.Right">
                <MudNavLink Href="/expenses" Icon="@Icons.Material.Filled.Payments" Class="nav-item">
                    Gastos
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Bancos" Placement="Placement.Right">
                <MudNavLink Href="/banking" Icon="@Icons.Material.Filled.AccountBalance" Class="nav-item">
                    Bancos
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Nómina" Placement="Placement.Right">
                <MudNavLink Href="/payroll" Icon="@Icons.Material.Filled.Badge" Class="nav-item">
                    Nómina
                </MudNavLink>
            </MudTooltip>
            
            <MudDivider Class="my-2 nav-divider" />
            
            <MudTooltip Text="Reportes" Placement="Placement.Right">
                <MudNavLink Href="/reports" Icon="@Icons.Material.Filled.Analytics" Class="nav-item">
                    Reportes
                </MudNavLink>
            </MudTooltip>
            
            <MudTooltip Text="Configuración" Placement="Placement.Right">
                <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings" Class="nav-item">
                    Ajustes
                </MudNavLink>
            </MudTooltip>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    <MudAlert Severity="Severity.Error" Dense="true">
        Se produjo un error. Por favor, recarga la página.
    </MudAlert>
    <button class="reload" onclick="location.reload()">Recargar</button>
    <button class="dismiss">Dismiss</button>
</div>

@code {
    private bool _drawerOpen;
    private readonly DateTime currentDate = DateTime.Now;
    private readonly CultureInfo spanishCulture = new CultureInfo("es-PA");

    protected override async Task OnInitializedAsync()
    {
        Theme.PropertyChanged += OnThemeChanged;
        await Theme.LoadPreferenceAsync();
    }

    private void OnThemeChanged(object? sender, PropertyChangedEventArgs e)
    {
        if (e.PropertyName == nameof(ThemeService.IsDarkMode) || e.PropertyName == nameof(ThemeService.CurrentTheme))
        {
            StateHasChanged();
        }
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private async Task ToggleTheme()
    {
        Theme.ToggleTheme();
        await Theme.SavePreferenceAsync();
    }

    private void Logout()
    {
        Navigation.NavigateTo("/login");
    }
}

<style>
    .app-bar-modern {
        background: linear-gradient(135deg, #2563EB 0%, #7C3AED 100%) !important;
    }
    
    .menu-btn {
        transition: transform 0.2s ease;
    }
    
    .menu-btn:hover {
        transform: scale(1.1);
    }
    
    .brand-text {
        font-weight: 700;
    }
    
    .brand-name {
        color: white;
    }
    
    .date-display {
        color: rgba(255, 255, 255, 0.9);
        font-weight: 500;
    }
    
    .icon-btn {
        transition: all 0.2s ease;
    }
    
    .icon-btn:hover {
        background: rgba(255, 255, 255, 0.15);
    }
    
    .sidebar-modern {
        background: var(--mud-palette-drawer-background) !important;
    }
    
    .sidebar-header {
        display: flex;
        justify-content: center;
        padding: 12px !important;
    }
    
    .nav-menu-custom {
        padding: 8px;
    }
    
    .nav-item {
        border-radius: 8px !important;
        margin-bottom: 2px !important;
        padding: 10px 12px !important;
    }
    
    .nav-item:hover {
        background: rgba(37, 99, 235, 0.08) !important;
    }
    
    .nav-item.active {
        background: rgba(37, 99, 235, 0.15) !important;
    }
    
    .nav-divider {
        margin: 8px 0 !important;
    }
    
    .main-content {
        min-height: calc(100vh - 64px);
    }
    
    :root {
        --font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    
    body {
        font-family: var(--font-family);
    }
    
    #blazor-error-ui {
        display: none;
    }
    
    /* Mobile Responsiveness */
    @@media (max-width: 600px) {
        .brand-name {
            display: none;
        }
        
        .app-bar-modern {
            padding: 0 8px !important;
        }
        
        .main-content {
            padding: 8px !important;
        }
        
        .mud-paper {
            border-radius: 12px !important;
        }
        
        .page-header-gradient {
            padding: 16px !important;
        }
        
        .page-header-gradient .mud-typography-h5 {
            font-size: 1.25rem !important;
        }
        
        .header-action-btn {
            font-size: 0.75rem !important;
            padding: 6px 12px !important;
        }
    }
</style>
