@inherits LayoutComponentBase
@inject NavigationManager Navigation

<MudThemeProvider Theme="currentTheme" @bind-IsDarkMode="@_isDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Style="background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3" Style="font-weight: 700;">ContabilidadPanama</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Brightness4" Color="Color.Inherit" OnClick="@ToggleDarkMode" />
        <MudIconButton Icon="@Icons.Material.Filled.Person" Color="Color.Inherit" />
    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen" Elevation="2" Style="background-color: #f8fafc;">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6" Style="font-weight: 700; color: #2563eb;">ContabilidadPanama</MudText>
        </MudDrawerHeader>

        <MudNavMenu>
            <MudNavLink Href="" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All">Dashboard</MudNavLink>
            <MudNavLink Href="invoices" Icon="@Icons.Material.Filled.Description">Facturas</MudNavLink>
            <MudNavLink Href="expenses" Icon="@Icons.Material.Filled.Payments">Gastos</MudNavLink>
            <MudNavLink Href="clients" Icon="@Icons.Material.Filled.People">Clientes</MudNavLink>
            <MudNavLink Href="products" Icon="@Icons.Material.Filled.Inventory2">Productos</MudNavLink>
            <MudNavLink Href="reports" Icon="@Icons.Material.Filled.Analytics">Reportes</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;

    private MudTheme currentTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#2563eb",
            Secondary = "#7c3aed",
            AppbarBackground = "#2563eb",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#3b82f6",
            Secondary = "#8b5cf6",
        }
    };

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
    }
}